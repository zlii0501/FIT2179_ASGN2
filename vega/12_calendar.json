{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": { "url": "data/hist_daily_continuous.csv" },
  "params": [
    { "name": "selectedStartA", "value": 5326 },
    { "name": "selectedStartB", "value": 4961 },
    { "name": "labelA0", "value": "Aug 2019" },
    { "name": "labelA1", "value": "Sep" },
    { "name": "labelA2", "value": "Oct" },
    { "name": "labelA3", "value": "Nov" },
    { "name": "labelB0", "value": "Aug 2018" },
    { "name": "labelB1", "value": "Sep" },
    { "name": "labelB2", "value": "Oct" },
    { "name": "labelB3", "value": "Nov" }
  ],
  "transform": [
    {
      "calculate": "['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][datum.weekday_order]",
      "as": "weekday_label"
    }
  ],
  "vconcat": [
    {
      "title": {
        "text": "Diagram A",
        "anchor": "start",
        "color": "#f0dcc0",
        "font": "sans-serif",
        "fontSize": 12,
        "fontWeight": "bold",
        "offset": 8
      },
      "width": "container",
      "height": 118,
      "transform": [
        { "filter": "datum.day_index >= selectedStartA && datum.day_index < selectedStartA + 122" },
        { "calculate": "datum.day_index - selectedStartA", "as": "window_day" },
        { "calculate": "floor(datum.window_day / 7)", "as": "window_week" },
        { "calculate": "datum.window_week < 10 ? '0' + datum.window_week : '' + datum.window_week", "as": "window_week_key" }
      ],
      "mark": {
        "type": "rect",
        "cornerRadius": 2,
        "stroke": "rgba(248,113,113,0.7)",
        "strokeWidth": 0.55
      },
      "encoding": {
        "x": {
          "field": "window_week_key",
          "type": "ordinal",
          "title": null,
          "sort": "ascending",
          "scale": {
            "domain": [
              "00",
              "01",
              "02",
              "03",
              "04",
              "05",
              "06",
              "07",
              "08",
              "09",
              "10",
              "11",
              "12",
              "13",
              "14",
              "15",
              "16",
              "17"
            ]
          },
          "axis": {
            "labelAngle": 0,
            "labelOverlap": false,
            "labelExpr": "{'00':labelA0,'04':labelA1,'08':labelA2,'13':labelA3}[datum.value] || ''"
          }
        },
        "y": {
          "field": "weekday_label",
          "type": "ordinal",
          "title": null,
          "sort": ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
          "axis": { "labelFontSize": 10 }
        },
        "color": {
          "field": "count",
          "type": "quantitative",
          "scale": {
            "scheme": "reds",
            "domain": [0, 3000],
            "clamp": true
          },
          "legend": {
            "title": "Daily detections",
            "orient": "bottom",
            "gradientLength": 180
          }
        },
        "tooltip": [
          { "field": "day_label", "title": "Date" },
          { "field": "period", "title": "Period" },
          { "field": "count", "type": "quantitative", "format": ",", "title": "Detections" }
        ]
      }
    },
    {
      "title": {
        "text": "Diagram B",
        "anchor": "start",
        "color": "#e8c9a0",
        "font": "sans-serif",
        "fontSize": 12,
        "fontWeight": "bold",
        "offset": 8
      },
      "width": "container",
      "height": 118,
      "transform": [
        { "filter": "datum.day_index >= selectedStartB && datum.day_index < selectedStartB + 122" },
        { "calculate": "datum.day_index - selectedStartB", "as": "window_day" },
        { "calculate": "floor(datum.window_day / 7)", "as": "window_week" },
        { "calculate": "datum.window_week < 10 ? '0' + datum.window_week : '' + datum.window_week", "as": "window_week_key" }
      ],
      "mark": {
        "type": "rect",
        "cornerRadius": 2,
        "stroke": "rgba(0,0,0,0.3)",
        "strokeWidth": 0.55
      },
      "encoding": {
        "x": {
          "field": "window_week_key",
          "type": "ordinal",
          "title": null,
          "sort": "ascending",
          "scale": {
            "domain": [
              "00",
              "01",
              "02",
              "03",
              "04",
              "05",
              "06",
              "07",
              "08",
              "09",
              "10",
              "11",
              "12",
              "13",
              "14",
              "15",
              "16",
              "17"
            ]
          },
          "axis": {
            "labelAngle": 0,
            "labelOverlap": false,
            "labelExpr": "{'00':labelB0,'04':labelB1,'08':labelB2,'13':labelB3}[datum.value] || ''"
          }
        },
        "y": {
          "field": "weekday_label",
          "type": "ordinal",
          "title": null,
          "sort": ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
          "axis": { "labelFontSize": 10 }
        },
        "color": {
          "field": "count",
          "type": "quantitative",
          "scale": {
            "scheme": "reds",
            "domain": [0, 3000],
            "clamp": true
          },
          "legend": {
            "title": "Daily detections",
            "orient": "bottom",
            "gradientLength": 180
          }
        },
        "tooltip": [
          { "field": "day_label", "title": "Date" },
          { "field": "period", "title": "Period" },
          { "field": "count", "type": "quantitative", "format": ",", "title": "Detections" }
        ]
      }
    }
  ],
  "spacing": 18,
  "resolve": {
    "scale": {
      "color": "shared",
      "x": "shared"
    }
  },
  "config": {
    "legend": {
      "labelColor": "#9ca3af",
      "titleColor": "#b8956a"
    },
    "axis": {
      "labelColor": "#9ca3af",
      "titleColor": "#b8956a"
    }
  }
}
