{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 940,
  "height": 500,
  "padding": 0,
  "background": "transparent",
  "signals": [
    { "name": "selectedState", "value": "ALL" },
    { "name": "requestedState", "value": "ALL" },
    { "name": "visibleStateA", "value": "ALL" },
    { "name": "visibleStateB", "value": "" },
    { "name": "binResolution", "value": "coarse" },
    { "name": "coarseBinFade", "value": 1 },
    { "name": "fineBinFadeA", "value": 0 },
    { "name": "fineBinFadeB", "value": 0 },
    { "name": "mapScale", "value": 680 },
    { "name": "mapTx", "value": 470 },
    { "name": "mapTy", "value": 250 }
  ],
  "projections": [
    {
      "name": "aus",
      "type": "mercator",
      "center": [134.5, -27.4],
      "scale": { "signal": "mapScale" },
      "translate": [{ "signal": "mapTx" }, { "signal": "mapTy" }]
    }
  ],
  "data": [
    {
      "name": "states",
      "url": "data/australia_states.geojson",
      "format": { "type": "json", "property": "features" },
      "transform": [
        {
          "type": "formula",
          "as": "state_abbr",
          "expr": "datum.properties.STATE_NAME === 'New South Wales' || datum.properties.STATE_NAME === 'Australian Capital Territory' ? 'NSW' : datum.properties.STATE_NAME === 'Queensland' ? 'QLD' : datum.properties.STATE_NAME === 'Western Australia' ? 'WA' : datum.properties.STATE_NAME === 'Northern Territory' ? 'NT' : datum.properties.STATE_NAME === 'South Australia' ? 'SA' : datum.properties.STATE_NAME === 'Victoria' ? 'VIC' : datum.properties.STATE_NAME === 'Tasmania' ? 'TAS' : 'OTHER'"
        }
      ]
    },
    {
      "name": "hexbins",
      "url": "data/hex_bins.geojson",
      "format": { "type": "json", "property": "features" }
    },
    {
      "name": "fineHexbins",
      "url": "data/hex_bins_fine.geojson",
      "format": { "type": "json", "property": "features" }
    },
    {
      "name": "visibleHexbins",
      "source": "hexbins",
      "transform": [
        {
          "type": "filter",
          "expr": "binResolution === 'coarse' && (visibleStateA === 'ALL' || datum.properties.state === visibleStateA || datum.properties.state === visibleStateB)"
        }
      ]
    },
    {
      "name": "visibleFineHexbins",
      "source": "fineHexbins",
      "transform": [
        {
          "type": "filter",
          "expr": "binResolution === 'fine' && (visibleStateA === 'ALL' || datum.properties.state === visibleStateA || datum.properties.state === visibleStateB)"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "countColor",
      "type": "sqrt",
      "domain": [1, 41],
      "range": ["#f8d48a", "#f97316", "#dc2626", "#7f1d1d"]
    },
    {
      "name": "fineCountColor",
      "type": "sqrt",
      "domain": [1, 22],
      "range": ["#f8d48a", "#f97316", "#dc2626", "#7f1d1d"]
    }
  ],
  "marks": [
    {
      "type": "shape",
      "from": { "data": "states" },
      "encode": {
        "enter": {
          "fill": { "value": "#0f1c28" },
          "stroke": { "value": "rgba(190,210,220,0.14)" },
          "strokeWidth": { "value": 0.65 }
        }
      },
      "transform": [{ "type": "geoshape", "projection": "aus" }]
    },
    {
      "type": "shape",
      "from": { "data": "visibleHexbins" },
      "encode": {
        "enter": {
          "aria": { "value": true },
          "description": {
            "signal": "datum.properties.count > 0 ? 'State: ' + datum.properties.state + '; Detections: ' + format(datum.properties.count, ',') + '; Avg FRP (MW): ' + format(datum.properties.avg_frp, '.1f') + '; Main month: ' + datum.properties.month : 'State: ' + datum.properties.state + '; Detections: No detections'"
          },
          "tooltip": { "value": false }
        },
        "update": {
          "fill": [
            { "test": "datum.properties.count === 0", "value": "#172635" },
            { "scale": "countColor", "field": "properties.count" }
          ],
          "fillOpacity": [
            { "test": "datum.properties.count === 0", "signal": "0.18 * coarseBinFade" },
            { "signal": "0.97 * coarseBinFade" }
          ],
          "stroke": [
            { "test": "datum.properties.count === 0", "value": "rgba(190,210,220,0.09)" },
            { "value": "rgba(8,13,22,0.9)" }
          ],
          "strokeWidth": [
            { "test": "datum.properties.count === 0", "value": 0.3 },
            { "value": 0.32 }
          ],
          "strokeOpacity": { "signal": "coarseBinFade" }
        },
        "hover": {
          "stroke": [
            { "test": "datum.properties.count === 0", "value": "rgba(190,210,220,0.09)" },
            { "value": "rgba(232,201,160,0.95)" }
          ],
          "strokeWidth": [
            { "test": "datum.properties.count === 0", "value": 0.3 },
            { "value": 1.8 }
          ],
          "strokeOpacity": { "value": 1 }
        }
      },
      "transform": [{ "type": "geoshape", "projection": "aus" }]
    },
    {
      "type": "shape",
      "from": { "data": "visibleFineHexbins" },
      "encode": {
        "enter": {
          "aria": { "value": true },
          "description": {
            "signal": "datum.properties.count > 0 ? 'State: ' + datum.properties.state + '; Detections: ' + format(datum.properties.count, ',') + '; Avg FRP (MW): ' + format(datum.properties.avg_frp, '.1f') + '; Main month: ' + datum.properties.month : 'State: ' + datum.properties.state + '; Detections: No detections'"
          },
          "tooltip": { "value": false }
        },
        "update": {
          "fill": [
            { "test": "datum.properties.count === 0", "value": "#172635" },
            { "scale": "fineCountColor", "field": "properties.count" }
          ],
          "fillOpacity": [
            { "signal": "(datum.properties.count === 0 ? 0.16 : 0.97) * (datum.properties.state === visibleStateB ? fineBinFadeB : fineBinFadeA)" }
          ],
          "stroke": [
            { "test": "datum.properties.count === 0", "value": "rgba(190,210,220,0.08)" },
            { "value": "rgba(8,13,22,0.86)" }
          ],
          "strokeWidth": [
            { "test": "datum.properties.count === 0", "value": 0.22 },
            { "value": 0.16 }
          ],
          "strokeOpacity": { "signal": "datum.properties.state === visibleStateB ? fineBinFadeB : fineBinFadeA" }
        },
        "hover": {
          "stroke": [
            { "test": "datum.properties.count === 0", "value": "rgba(190,210,220,0.08)" },
            { "value": "rgba(232,201,160,0.95)" }
          ],
          "strokeWidth": [
            { "test": "datum.properties.count === 0", "value": 0.22 },
            { "value": 1.8 }
          ],
          "strokeOpacity": { "value": 1 }
        }
      },
      "transform": [{ "type": "geoshape", "projection": "aus" }]
    },
    {
      "type": "shape",
      "interactive": false,
      "from": { "data": "states" },
      "encode": {
        "enter": {
          "fill": { "value": "transparent" },
          "stroke": { "value": "rgba(210,225,230,0.26)" },
          "strokeWidth": { "value": 0.65 }
        }
      },
      "transform": [{ "type": "geoshape", "projection": "aus" }]
    }
  ]
}
