{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Streamgraph of monthly fire detection counts by Australian state",
  "width": "container",
  "height": 205,
  "background": "transparent",
  "data": {
    "url": "data/fire_monthly_state.csv"
  },
  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "opacity": 0.85
  },
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "axis": {
        "labelExpr": "{'2019-08':'Aug 2019','2019-09':'Sep 2019','2019-10':'Oct 2019','2019-11':'Nov 2019','2019-12':'Dec 2019','2020-01':'Jan 2020'}[datum.value] || datum.value",
        "title": null,
        "grid": false,
        "labelAngle": -35,
        "labelFontSize": 10,
        "labelLimit": 80
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "stack": "center",
      "axis": null
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "scale": {
        "domain": ["NSW", "QLD", "WA", "NT", "SA", "VIC"],
        "range": ["#D55E00", "#E69F00", "#0072B2", "#CC79A7", "#009E73", "#56B4E9"]
      },
      "legend": null
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "month", "type": "ordinal", "title": "Month"},
      {"field": "count", "type": "quantitative", "title": "Fire Detections", "format": ","}
    ]
  }
}
