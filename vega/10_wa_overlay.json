            "strokeWidth": 1.2
          },
          "encoding": {
            "theta": {
              "field": "theta_start",
              "type": "quantitative",
              "scale": { "domain": [0, 6.283185307179586], "range": [0, 6.283185307179586] },
              "axis": null
            },
            "theta2": { "field": "theta_end" },
            "radius": {
