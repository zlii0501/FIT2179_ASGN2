              "scale": {
                "domain": [50, 330],
                "range": ["#ffd166", "#f8961e", "#e74c3c", "#7f1d1d"]
              },
              "legend": null
            },
            "tooltip": [
              { "field": "month_label_long", "title": "Month" },
              { "field": "avg_frp", "title": "Avg FRP (MW)", "format": ".1f" },
              { "field": "max_daily_frp", "title": "Max daily mean FRP (MW)", "format": ".1f" },
              { "field": "detection_count", "title": "Detections", "format": "," },
              { "field": "period", "title": "Period" }
            ]
          }
        },
        {
          "transform": [{ "filter": "datum.month_order === 0" }],
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "top",
            "font": "sans-serif",
            "fontSize": 12,
            "fontWeight": "bold",
            "fill": "#f0dcc0"
          },
          "encoding": {
            "x": { "value": 0 },
