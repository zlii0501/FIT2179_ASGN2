            "fill": "#e8c9a0"
          },
          "encoding": {
            "x": { "value": 0 },
            "y": { "value": 18 },
            "text": { "value": "Diagram B" }
          }
        },
        {
          "mark": {
            "type": "point",
            "shape": "square",
            "filled": true,
            "size": 60,
            "stroke": "#0d1117",
            "strokeWidth": 1
          },
          "encoding": {
            "x": { "value": 300 },
            "y": {
              "field": "outer_r",
              "type": "quantitative",
              "scale": { "domain": [30, 110], "range": [222, 110] },
              "axis": null
            },
            "color": {
              "field": "avg_frp",
              "type": "quantitative",
              "scale": {
                "domain": [50, 330],
                "range": ["#ffd166", "#f8961e", "#e74c3c", "#7f1d1d"]
              },
              "legend": null
            }
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "middle",
            "font": "Courier New",
            "fontSize": 10,
            "fontWeight": "bold",
            "fill": "#f0dcc0"
          },
          "encoding": {
            "x": { "value": 312 },
            "y": {
              "field": "outer_r",
              "type": "quantitative",
              "scale": { "domain": [30, 110], "range": [222, 110] },
              "axis": null
            },
            "text": { "field": "legend_label" }
          }
        }
      ]
    }
  ],
  "spacing": 20,
  "resolve": {
    "scale": {
      "color": "shared"
    }
  },
  "config": {
    "axis": { "grid": false },
    "view": { "stroke": null }
  }
}
