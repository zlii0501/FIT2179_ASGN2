{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 230,
  "data": { "sequence": { "start": 0, "stop": 100, "as": "i" } },
  "transform": [
    {
      "calculate": "datum.i < 51 ? 'NSW' : datum.i < 68 ? 'QLD' : datum.i < 85 ? 'WA' : datum.i < 98 ? 'NT' : datum.i < 99 ? 'SA' : 'VIC'",
      "as": "state"
    },
    {
      "calculate": "datum.state === 'NSW' ? '101,569 detections - 51%' : datum.state === 'QLD' ? '34,158 detections - 17%' : datum.state === 'WA' ? '33,964 detections - 17%' : datum.state === 'NT' ? '26,037 detections - 13%' : datum.state === 'SA' ? '2,834 detections - 1.4%' : '845 detections - 0.4%'",
      "as": "detail"
    },
    {
      "calculate": "datum.i < 30 ? 0 : datum.i < 56 ? 1 : datum.i < 78 ? 2 : datum.i < 92 ? 3 : 4",
      "as": "ring"
    },
    {
      "calculate": "datum.i < 30 ? datum.i : datum.i < 56 ? datum.i - 30 : datum.i < 78 ? datum.i - 56 : datum.i < 92 ? datum.i - 78 : datum.i - 92",
      "as": "seat"
    },
    {
      "calculate": "datum.ring === 0 ? 30 : datum.ring === 1 ? 26 : datum.ring === 2 ? 22 : datum.ring === 3 ? 14 : 8",
      "as": "ring_count"
    },
    {
      "calculate": "datum.ring === 0 ? 150 : datum.ring === 1 ? 124 : datum.ring === 2 ? 98 : datum.ring === 3 ? 72 : 46",
      "as": "radius"
    },
    {
      "calculate": "3.141592653589793 - (datum.seat + 0.5) / datum.ring_count * 3.141592653589793",
      "as": "angle"
    },
    {
      "calculate": "cos(datum.angle) * datum.radius",
      "as": "x_pos"
    },
    {
      "calculate": "sin(datum.angle) * datum.radius",
      "as": "y_pos"
    }
  ],
  "mark": {
    "type": "point",
    "shape": "M0,-1.35 C0.42,-0.78 0.96,-0.34 0.92,0.36 C0.88,1.05 0.34,1.42 -0.2,1.42 C-0.88,1.42 -1.26,0.92 -1.12,0.28 C-1.0,-0.24 -0.62,-0.58 -0.48,-1.08 C-0.2,-0.76 -0.04,-0.44 0,-1.35 Z",
    "filled": true,
    "size": 500,
    "stroke": "#111827",
    "strokeWidth": 1.15
  },
  "encoding": {
    "x": {
      "field": "x_pos",
      "type": "quantitative",
      "scale": { "domain": [-168, 168] },
      "axis": null
    },
    "y": {
      "field": "y_pos",
      "type": "quantitative",
      "scale": { "domain": [-14, 168] },
      "axis": null
    },
    "color": {
      "field": "state",
      "type": "nominal",
      "scale": {
        "domain": ["NSW", "QLD", "WA", "NT", "SA", "VIC"],
        "range": ["#c94f44", "#b96f3a", "#b8956a", "#d0a34a", "#7f8f6a", "#6f9a9a"]
      },
      "legend": null
    },
    "tooltip": [
      { "field": "state", "title": "State" },
      { "field": "detail", "title": "Share" }
    ]
  }
}
