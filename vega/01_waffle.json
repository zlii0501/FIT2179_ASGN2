{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "padding": { "left": 0, "right": 8, "top": 4, "bottom": 4 },
  "params": [{"name": "hoveredState", "value": ""}],
  "data": { "sequence": { "start": 0, "stop": 325, "as": "i" } },
  "transform": [
    {
      "calculate": "datum.i < 125 ? 'NSW' : datum.i < 175 ? 'QLD' : datum.i < 225 ? 'WA' : datum.i < 275 ? 'NT' : datum.i < 300 ? 'SA' : 'VIC'",
      "as": "state"
    },
    {
      "calculate": "datum.i < 125 ? datum.i : datum.i < 175 ? datum.i - 125 : datum.i < 225 ? datum.i - 175 : datum.i < 275 ? datum.i - 225 : datum.i < 300 ? datum.i - 275 : datum.i - 300",
      "as": "pos_in_state"
    },
    {
      "calculate": "datum.state === 'NSW' ? 101 : datum.state === 'QLD' ? 34 : datum.state === 'WA' ? 33 : datum.state === 'NT' ? 26 : datum.state === 'SA' ? 2 : 0",
      "as": "full_count"
    },
    {
      "calculate": "datum.state === 'NSW' ? 0.569 : datum.state === 'QLD' ? 0.158 : datum.state === 'WA' ? 0.964 : datum.state === 'NT' ? 0.037 : datum.state === 'SA' ? 0.834 : 0.845",
      "as": "frac_value"
    },
    {
      "calculate": "datum.pos_in_state < datum.full_count ? 'full' : (datum.pos_in_state === datum.full_count ? 'fractional' : 'outline')",
      "as": "cell_type"
    },
    {
      "calculate": "datum.cell_type === 'full' ? 1 : (datum.cell_type === 'fractional' ? max(0.18, datum.frac_value) : 0)",
      "as": "fill_opacity"
    },
    {
      "calculate": "datum.pos_in_state % 25",
      "as": "col"
    },
    {
      "calculate": "floor(datum.pos_in_state / 25)",
      "as": "sub_row"
    },
    {
      "calculate": "datum.state === 'NSW' ? 0 : datum.state === 'QLD' ? 5 : datum.state === 'WA' ? 7 : datum.state === 'NT' ? 9 : datum.state === 'SA' ? 11 : 12",
      "as": "state_offset"
    },
    {
      "calculate": "datum.state_offset + datum.sub_row",
      "as": "y"
    },
    {
      "calculate": "datum.state === 'NSW' ? '101,569 detections · 51.0%' : datum.state === 'QLD' ? '34,158 detections · 17.1%' : datum.state === 'WA' ? '33,964 detections · 17.0%' : datum.state === 'NT' ? '26,037 detections · 13.1%' : datum.state === 'SA' ? '2,834 detections · 1.4%' : '845 detections · 0.4%'",
      "as": "detail"
    },
    {
      "calculate": "datum.state === 'NSW' ? '101.6 flames' : datum.state === 'QLD' ? '34.2 flames' : datum.state === 'WA' ? '34.0 flames' : datum.state === 'NT' ? '26.0 flames' : datum.state === 'SA' ? '2.8 flames' : '0.8 flames'",
      "as": "flame_label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "point",
        "shape": "M0,-1.35 C0.42,-0.78 0.96,-0.34 0.92,0.36 C0.88,1.05 0.34,1.42 -0.2,1.42 C-0.88,1.42 -1.26,0.92 -1.12,0.28 C-1.0,-0.24 -0.62,-0.58 -0.48,-1.08 C-0.2,-0.76 -0.04,-0.44 0,-1.35 Z",
        "size": 200
      },
      "encoding": {
        "x": {
          "field": "col",
          "type": "quantitative",
          "scale": { "domain": [-3, 24.6] },
          "axis": null
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": { "domain": [-0.5, 12.5], "reverse": true },
          "axis": null
        },
        "fill": {
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": ["NSW", "QLD", "WA", "NT", "SA", "VIC"],
            "range": ["#D55E00", "#E69F00", "#0072B2", "#CC79A7", "#009E73", "#56B4E9"]
          },
          "legend": null
        },
        "fillOpacity": {
          "field": "fill_opacity",
          "type": "quantitative",
          "scale": null,
          "legend": null
        },
        "stroke": {
          "condition": [
            {"test": "datum.cell_type === 'outline'", "value": "rgba(232,201,160,0.32)"}
          ],
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": ["NSW", "QLD", "WA", "NT", "SA", "VIC"],
            "range": ["#D55E00", "#E69F00", "#0072B2", "#CC79A7", "#009E73", "#56B4E9"]
          },
          "legend": null
        },
        "strokeWidth": {
          "condition": [
            {"test": "datum.cell_type === 'outline'", "value": 1.1},
            {"test": "datum.cell_type === 'fractional'", "value": 1.4}
          ],
          "value": 0.8
        },
        "opacity": {
          "condition": [
            {"test": "hoveredState !== '' && datum.state === hoveredState", "value": 1},
            {"test": "hoveredState !== ''", "value": 0.12}
          ],
          "value": 1
        },
        "tooltip": [
          { "field": "state", "title": "State" },
          { "field": "flame_label", "title": "Total flames" },
          { "field": "detail", "title": "Detections" }
        ]
      }
    },
    {
      "data": {
        "values": [
          {"state": "NSW", "y": 0,  "lbl_x": -1.6},
          {"state": "QLD", "y": 5,  "lbl_x": -1.6},
          {"state": "WA",  "y": 7,  "lbl_x": -1.6},
          {"state": "NT",  "y": 9,  "lbl_x": -1.6},
          {"state": "SA",  "y": 11, "lbl_x": -1.6},
          {"state": "VIC", "y": 12, "lbl_x": -1.6}
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#e8c9a0"
      },
      "encoding": {
        "text": {"field": "state"},
        "x": {
          "field": "lbl_x",
          "type": "quantitative",
          "scale": { "domain": [-3, 24.6] },
          "axis": null
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": { "domain": [-0.5, 12.5], "reverse": true },
          "axis": null
        },
        "opacity": {
          "condition": [
            {"test": "hoveredState !== '' && datum.state === hoveredState", "value": 1},
            {"test": "hoveredState !== ''", "value": 0.3}
          ],
          "value": 1
        }
      }
    }
  ]
}
