{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 320,
  "padding": { "left": 0, "right": 8, "top": 4, "bottom": 4 },
  "params": [{"name": "hoveredState", "value": ""}],
  "data": { "sequence": { "start": 0, "stop": 200, "as": "i" } },
  "transform": [
    {
      "calculate": "datum.i < 102 ? 'NSW' : datum.i < 136 ? 'QLD' : datum.i < 170 ? 'WA' : datum.i < 196 ? 'NT' : datum.i < 199 ? 'SA' : 'VIC'",
      "as": "state"
    },
    {
      "calculate": "datum.i < 102 ? datum.i : datum.i < 136 ? datum.i - 102 : datum.i < 170 ? datum.i - 136 : datum.i < 196 ? datum.i - 170 : datum.i < 199 ? datum.i - 196 : datum.i - 199",
      "as": "pos_in_state"
    },
    {
      "calculate": "datum.pos_in_state % 25",
      "as": "col"
    },
    {
      "calculate": "floor(datum.pos_in_state / 25)",
      "as": "sub_row"
    },
    {
      "calculate": "datum.state === 'NSW' ? 0 : datum.state === 'QLD' ? 5 : datum.state === 'WA' ? 7 : datum.state === 'NT' ? 9 : datum.state === 'SA' ? 11 : 12",
      "as": "state_offset"
    },
    {
      "calculate": "datum.state_offset + datum.sub_row",
      "as": "y"
    },
    {
      "calculate": "datum.state === 'NSW' ? '101,569 detections · 51%' : datum.state === 'QLD' ? '34,158 detections · 17%' : datum.state === 'WA' ? '33,964 detections · 17%' : datum.state === 'NT' ? '26,037 detections · 13%' : datum.state === 'SA' ? '2,834 detections · 1.4%' : '845 detections · 0.4%'",
      "as": "detail"
    },
    {
      "calculate": "datum.state === 'NSW' ? 102 : datum.state === 'QLD' ? 34 : datum.state === 'WA' ? 34 : datum.state === 'NT' ? 26 : datum.state === 'SA' ? 3 : 1",
      "as": "state_flames"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "point",
        "shape": "M0,-1.35 C0.42,-0.78 0.96,-0.34 0.92,0.36 C0.88,1.05 0.34,1.42 -0.2,1.42 C-0.88,1.42 -1.26,0.92 -1.12,0.28 C-1.0,-0.24 -0.62,-0.58 -0.48,-1.08 C-0.2,-0.76 -0.04,-0.44 0,-1.35 Z",
        "filled": true,
        "size": 200,
        "stroke": "#111827",
        "strokeWidth": 0.8
      },
      "encoding": {
        "x": {
          "field": "col",
          "type": "quantitative",
          "scale": { "domain": [-3, 24.6] },
          "axis": null
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": { "domain": [-0.5, 12.5], "reverse": true },
          "axis": null
        },
        "color": {
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": ["NSW", "QLD", "WA", "NT", "SA", "VIC"],
            "range": ["#D55E00", "#E69F00", "#0072B2", "#CC79A7", "#009E73", "#56B4E9"]
          },
          "legend": null
        },
        "opacity": {
          "condition": [
            {"test": "hoveredState !== '' && datum.state === hoveredState", "value": 1},
            {"test": "hoveredState !== ''", "value": 0.12}
          ],
          "value": 1
        },
        "tooltip": [
          { "field": "state", "title": "State" },
          { "field": "state_flames", "title": "Flames (~1k each)" },
          { "field": "detail", "title": "Total" }
        ]
      }
    },
    {
      "data": {
        "values": [
          {"state": "NSW", "y": 0,  "lbl_x": -1.6},
          {"state": "QLD", "y": 5,  "lbl_x": -1.6},
          {"state": "WA",  "y": 7,  "lbl_x": -1.6},
          {"state": "NT",  "y": 9,  "lbl_x": -1.6},
          {"state": "SA",  "y": 11, "lbl_x": -1.6},
          {"state": "VIC", "y": 12, "lbl_x": -1.6}
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#e8c9a0"
      },
      "encoding": {
        "text": {"field": "state"},
        "x": {
          "field": "lbl_x",
          "type": "quantitative",
          "scale": { "domain": [-3, 24.6] },
          "axis": null
        },
        "y": {
          "field": "y",
          "type": "quantitative",
          "scale": { "domain": [-0.5, 12.5], "reverse": true },
          "axis": null
        },
        "opacity": {
          "condition": [
            {"test": "hoveredState !== '' && datum.state === hoveredState", "value": 1},
            {"test": "hoveredState !== ''", "value": 0.3}
          ],
          "value": 1
        }
      }
    }
  ]
}
