{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "Month to state to FRP intensity alluvial diagram — responsive column spacing.",
  "width": 1100,
  "height": 1050,
  "padding": { "left": 8, "right": 40, "top": 10, "bottom": 18 },
  "autosize": "none",
  "background": "transparent",
  "signals": [
    {
      "name": "hoverLink",
      "value": null,
      "on": [
        { "events": "@flow:mouseover", "update": "datum" },
        { "events": "@flow:mouseout", "update": "null" }
      ]
    },
    {
      "name": "hoverNode",
      "value": null,
      "on": [
        { "events": "@node:mouseover", "update": "datum.id" },
        { "events": "@node:mouseout", "update": "null" }
      ]
    },
    { "name": "monthCX", "update": "width * 0.131" },
    { "name": "stateCX", "update": "width * 0.500" },
    { "name": "frpCX",   "update": "width * 0.890" },
    { "name": "scaleY",  "update": "height / 700" },
    { "name": "nodeHW",  "update": "round(11 * height / 700)" }
  ],
  "data": [
    {
      "name": "links",
      "url": "data/alluvial_month_state_intensity.json?v=fit-shell-20260524",
      "format": { "type": "json", "property": "links" },
      "transform": [
        {
          "type": "formula",
          "as": "srcX1",
          "expr": "datum.type === 'month-state' ? monthCX + nodeHW : stateCX + nodeHW"
        },
        {
          "type": "formula",
          "as": "tgtX0",
          "expr": "datum.type === 'month-state' ? stateCX - nodeHW : frpCX - nodeHW"
        },
        {
          "type": "formula",
          "as": "midX",
          "expr": "(datum.srcX1 + datum.tgtX0) / 2"
        },
        {
          "type": "formula",
          "as": "src_ys",
          "expr": "datum.source_y * scaleY"
        },
        {
          "type": "formula",
          "as": "tgt_ys",
          "expr": "datum.target_y * scaleY"
        },
        {
          "type": "formula",
          "as": "pathR",
          "expr": "'M' + datum.srcX1 + ',' + datum.src_ys + ' C' + datum.midX + ',' + datum.src_ys + ' ' + datum.midX + ',' + datum.tgt_ys + ' ' + datum.tgtX0 + ',' + datum.tgt_ys"
        },
        {
          "type": "formula",
          "as": "strokeWidthR",
          "expr": "max(1.2, datum.strokeWidth * scaleY)"
        }
      ]
    },
    {
      "name": "nodes",
      "url": "data/alluvial_month_state_intensity.json?v=fit-shell-20260524",
      "format": { "type": "json", "property": "nodes" },
      "transform": [
        {
          "type": "formula",
          "as": "cx",
          "expr": "datum.column === 'month' ? monthCX : datum.column === 'state' ? stateCX : frpCX"
        },
        { "type": "formula", "as": "x0r", "expr": "datum.cx - nodeHW" },
        { "type": "formula", "as": "x1r", "expr": "datum.cx + nodeHW" },
        { "type": "formula", "as": "y0s", "expr": "datum.y0 * scaleY" },
        { "type": "formula", "as": "y1s", "expr": "datum.y1 * scaleY" },
        { "type": "formula", "as": "ycs", "expr": "datum.yc * scaleY" }
      ]
    },
    {
      "name": "columns",
      "values": [
        { "label": "MONTH",         "colKey": "month" },
        { "label": "STATE",         "colKey": "state" },
        { "label": "FRP INTENSITY", "colKey": "intensity" }
      ],
      "transform": [
        {
          "type": "formula",
          "as": "xr",
          "expr": "datum.colKey === 'month' ? monthCX : datum.colKey === 'state' ? stateCX : frpCX"
        }
      ]
    }
  ],
  "marks": [
    {
      "type": "text",
      "from": { "data": "columns" },
      "encode": {
        "enter": {
          "y": { "value": -2 },
          "text": { "field": "label" },
          "align": { "value": "center" },
          "baseline": { "value": "top" },
          "font": { "value": "Courier New" },
          "fontSize": { "value": 19 },
          "fontWeight": { "value": "bold" },
          "letterSpacing": { "value": 2.5 },
          "fill": { "value": "#b8956a" }
        },
        "update": {
          "x": { "field": "xr" }
        }
      }
    },
    {
      "name": "flow",
      "type": "path",
      "from": { "data": "links" },
      "encode": {
        "enter": {
          "stroke": { "field": "color" },
          "strokeWidth": { "field": "strokeWidthR" },
          "strokeCap": { "value": "butt" },
          "fill": { "value": null },
          "aria": { "value": true },
          "description": {
            "signal": "'Flow: ' + datum.label + '; Detections: ' + format(datum.count, ',')"
          },
          "tooltip": {
            "signal": "{'Flow': datum.label, 'Detections': format(datum.count, ',')}"
          }
        },
        "update": {
          "path": { "field": "pathR" },
          "strokeOpacity": [
            {
              "test": "hoverLink && datum.source === hoverLink.source && datum.target === hoverLink.target",
              "value": 0.92
            },
            {
              "test": "hoverNode && (datum.source === hoverNode || datum.target === hoverNode)",
              "value": 0.78
            },
            {
              "test": "hoverLink || hoverNode",
              "value": 0.12
            },
            { "value": 0.34 }
          ],
          "zindex": [
            {
              "test": "hoverLink && datum.source === hoverLink.source && datum.target === hoverLink.target",
              "value": 3
            },
            {
              "test": "hoverNode && (datum.source === hoverNode || datum.target === hoverNode)",
              "value": 2
            },
            { "value": 0 }
          ]
        },
        "hover": {
          "strokeOpacity": { "value": 0.9 }
        }
      }
    },
    {
      "name": "node",
      "type": "rect",
      "from": { "data": "nodes" },
      "encode": {
        "enter": {
          "cornerRadius": { "value": 3 },
          "fill": { "field": "color" },
          "stroke": { "value": "rgba(240,220,192,0.28)" },
          "strokeWidth": { "value": 0.8 },
          "aria": { "value": true },
          "description": {
            "signal": "'Node: ' + datum.label + '; Column: ' + datum.columnLabel + '; Detections: ' + format(datum.count, ',')"
          },
          "tooltip": {
            "signal": "{'Node': datum.label, 'Column': datum.columnLabel, 'Detections': format(datum.count, ',')}"
          }
        },
        "update": {
          "x": { "field": "x0r" },
          "x2": { "field": "x1r" },
          "y": { "field": "y0s" },
          "y2": { "field": "y1s" },
          "fillOpacity": [
            { "test": "hoverNode === datum.id", "value": 1 },
            { "test": "hoverLink && (datum.id === hoverLink.source || datum.id === hoverLink.target)", "value": 1 },
            { "test": "hoverNode || hoverLink", "value": 0.38 },
            { "value": 0.9 }
          ]
        }
      }
    },
    {
      "type": "text",
      "from": { "data": "nodes" },
      "encode": {
        "enter": {
          "text": { "field": "label" },
          "baseline": { "value": "middle" },
          "font": { "value": "Georgia" },
          "fontSize": { "value": 20 },
          "fontWeight": { "value": "bold" },
          "fill": { "value": "#f0dcc0" }
        },
        "update": {
          "x": { "signal": "datum.column === 'intensity' ? datum.x1r + 8 : datum.x0r - 8" },
          "y": { "field": "ycs" },
          "align": { "signal": "datum.column === 'intensity' ? 'left' : 'right'" },
          "fillOpacity": [
            { "test": "hoverNode === datum.id", "value": 1 },
            { "test": "hoverLink && (datum.id === hoverLink.source || datum.id === hoverLink.target)", "value": 1 },
            { "test": "hoverNode || hoverLink", "value": 0.42 },
            { "value": 0.92 }
          ]
        }
      }
    },
    {
      "type": "text",
      "from": { "data": "nodes" },
      "encode": {
        "enter": {
          "text": { "signal": "format(datum.count, ',')" },
          "baseline": { "value": "middle" },
          "font": { "value": "Courier New" },
          "fontSize": { "value": 16 },
          "fill": { "value": "#9ca3af" }
        },
        "update": {
          "x": { "signal": "datum.column === 'intensity' ? datum.x1r + 8 : datum.x0r - 8" },
          "y": { "signal": "datum.ycs + 27" },
          "align": { "signal": "datum.column === 'intensity' ? 'left' : 'right'" },
          "fillOpacity": [
            { "test": "datum.column === 'state'", "value": 0 },
            { "test": "hoverNode === datum.id", "value": 1 },
            { "test": "hoverLink && (datum.id === hoverLink.source || datum.id === hoverLink.target)", "value": 1 },
            { "test": "hoverNode || hoverLink", "value": 0.35 },
            { "value": 0.82 }
          ]
        }
      }
    }
  ]
}
