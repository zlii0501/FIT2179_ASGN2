{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 260,
  "padding": {"left": 8, "top": 12, "right": 8, "bottom": 18},
  "data": {"url": "data/fire_monthly_state.csv"},
  "transform": [
    {
      "calculate": "{'2019-08':'Aug 2019','2019-09':'Sep 2019','2019-11':'Nov 2019','2019-12':'Dec 2019','2020-01':'Jan 2020'}[datum.month]",
      "as": "month_label"
    }
  ],
  "mark": {
    "type": "circle",
    "filled": true,
    "opacity": 0.9,
    "stroke": "#0d1117",
    "strokeWidth": 1.1
  },
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "title": null,
      "sort": ["2019-08","2019-09","2019-11","2019-12","2020-01"],
      "axis": {
        "labelAngle": 0,
        "labelOverlap": false,
        "labelFontSize": 10,
        "labelPadding": 6,
        "labelExpr": "{'2019-08':'Aug 2019','2019-09':'Sep','2019-11':'Nov','2019-12':'Dec','2020-01':'Jan 2020'}[datum.label]"
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {"field": "count", "op": "sum", "order": "descending"},
      "title": null,
      "axis": {"labelFontSize": 11}
    },
    "size": {
      "field": "count",
      "type": "quantitative",
      "scale": {
        "type": "sqrt",
        "domain": [0, 45000],
        "range": [45, 1800]
      },
      "legend": null
    },
    "color": {
      "field": "avg_frp",
      "type": "quantitative",
      "scale": {
        "domain": [0, 250],
        "clamp": true,
        "range": ["#e09848", "#cf7025", "#b85a22", "#8a3c12", "#5a2410", "#3d1a08"]
      },
      "legend": null
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "month_label", "type": "ordinal", "title": "Month"},
      {"field": "count", "type": "quantitative", "title": "Detections", "format": ","},
      {"field": "avg_frp", "type": "quantitative", "title": "Avg FRP (MW)", "format": ".1f"},
      {"field": "total_frp", "type": "quantitative", "title": "Total Energy (MW)", "format": ",.0f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {
      "labelColor": "#9ca3af",
      "titleColor": "#b8956a"
    }
  }
}
