{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 220,
  "padding": {"left": 8, "top": 12, "right": 8, "bottom": 32},
  "data": {"url": "data/fire_monthly_state.csv"},
  "transform": [
    {
      "calculate": "{'2019-08':'Aug 2019','2019-09':'Sep 2019','2019-10':'Oct 2019','2019-11':'Nov 2019','2019-12':'Dec 2019','2020-01':'Jan 2020'}[datum.month]",
      "as": "month_label"
    }
  ],
  "mark": {"type": "rect", "cornerRadius": 3},
  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "title": null,
      "sort": ["2019-08","2019-09","2019-10","2019-11","2019-12","2020-01"],
      "axis": {
        "labelAngle": 0,
        "labelExpr": "{'2019-08':'Aug 2019','2019-09':'Sep','2019-10':'Oct','2019-11':'Nov','2019-12':'Dec','2020-01':'Jan 2020'}[datum.label]"
      }
    },
    "y": {
      "field": "state",
      "type": "nominal",
      "sort": {"field": "count", "op": "sum", "order": "descending"},
      "title": null,
      "axis": {"labelFontSize": 11}
    },
    "color": {
      "field": "avg_frp",
      "type": "quantitative",
      "scale": {
        "domain": [0, 180],
        "range": ["#130c04", "#4a1f06", "#8a3c12", "#c46228", "#e89040", "#f8c870"]
      },
      "legend": {
        "title": "Avg FRP (MW)",
        "orient": "bottom",
        "direction": "horizontal",
        "gradientLength": 200,
        "gradientThickness": 10,
        "titleAnchor": "start",
        "labelFontSize": 10,
        "titleColor": "#b8956a",
        "labelColor": "#9ca3af"
      }
    },
    "tooltip": [
      {"field": "state", "type": "nominal", "title": "State"},
      {"field": "month_label", "type": "ordinal", "title": "Month"},
      {"field": "count", "type": "quantitative", "title": "Detections", "format": ","},
      {"field": "avg_frp", "type": "quantitative", "title": "Avg FRP (MW)", "format": ".1f"},
      {"field": "total_frp", "type": "quantitative", "title": "Total Energy (MW)", "format": ",.0f"}
    ]
  },
  "config": {
    "view": {"stroke": null},
    "axis": {
      "labelColor": "#9ca3af",
      "titleColor": "#b8956a"
    }
  }
}
