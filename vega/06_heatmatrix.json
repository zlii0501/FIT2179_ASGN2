{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Dumbbell chart showing fire detection escalation from August to December by state",
  "width": "container",
  "height": 280,
  "data": {"url": "data/fire_monthly_state.csv"},
  "transform": [
    {"filter": "datum.month === '2019-08' || datum.month === '2019-12'"},
    {
      "calculate": "datum.month === '2019-08' ? 'Aug 2019' : 'Dec 2019'",
      "as": "month_label"
    },
    {
      "calculate": "datum.month === '2019-08' ? 0 : 1",
      "as": "month_order"
    },
    {
      "calculate": "datum.month === '2019-12' ? datum.count : 0",
      "as": "dec_sort"
    },
    {
      "joinaggregate": [
        {"op": "max", "field": "dec_sort", "as": "dec_count"}
      ],
      "groupby": ["state"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "stroke": "rgba(232,201,160,0.45)",
        "strokeWidth": 2.2
      },
      "encoding": {
        "x": {
          "field": "count",
          "type": "quantitative",
          "title": "Fire detections (sqrt scale)",
          "scale": {"type": "sqrt", "domainMin": 0},
          "axis": {"format": "~s"}
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "dec_count", "order": "descending"},
          "title": null
        },
        "detail": {"field": "state"},
        "order": {"field": "month_order", "type": "quantitative"}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 155,
        "stroke": "#111827",
        "strokeWidth": 1.2
      },
      "encoding": {
        "x": {
          "field": "count",
          "type": "quantitative",
          "title": "Fire detections (sqrt scale)",
          "scale": {"type": "sqrt", "domainMin": 0},
          "axis": {"format": "~s"}
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "dec_count", "order": "descending"},
          "title": null
        },
        "color": {
          "field": "month_label",
          "type": "nominal",
          "scale": {
            "domain": ["Aug 2019", "Dec 2019"],
            "range": ["#6f9a9a", "#c94f44"]
          },
          "legend": null
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "month_label", "title": "Month"},
          {"field": "count", "title": "Detections", "format": ","},
          {"field": "avg_frp", "title": "Avg FRP (MW)", "format": ".1f"},
          {"field": "total_frp", "title": "Total FRP (MW)", "format": ",.0f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.month === '2019-12'"}],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "font": "Courier New, monospace",
        "fontSize": 11,
        "fontWeight": "bold",
        "fill": "#f0dcc0"
      },
      "encoding": {
        "x": {
          "field": "count",
          "type": "quantitative",
          "scale": {"type": "sqrt", "domainMin": 0}
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {"field": "dec_count", "order": "descending"}
        },
        "text": {"field": "count", "type": "quantitative", "format": "~s"}
      }
    }
  ]
}
